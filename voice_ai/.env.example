# Voice AI Gateway

# URL của Backend để gọi API chat/internal/voice
BACKEND_INTERNAL_CHAT_URL=http://localhost:8000/chat/internal/voice

# API Keys (TUYỆT ĐỐI KHÔNG ĐIỀN KEY THẬT VÀO FILE NÀY VÀ PUSH LÊN GITHUB)
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
CARTESIA_API_KEY=your_cartesia_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Mô hình
TTS_MODEL=openai
RESPONSE_MODEL=groq
STT_MODEL=deepgram

# (Tùy chọn) Nếu Voice AI cần gọi trực tiếp DB (Tuy nhiên hiện tại Voice AI đóng vai trò Gateway nên không cần)
DATABASE_URL=postgresql+psycopg2://user:pass@127.0.0.1:5432/dbname
